<http://example.org/recipes/Drink/57> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "El naranjillazo es una bebida ecuatoriana y una de las variaciones más populares del canelazo. Se prepara con jugo de naranjilla, una fruta de sabor ácido típica de Ecuador."^^xsd:string ;
