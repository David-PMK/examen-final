<http://example.org/recipes/Main_Dish/22> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Main_Dish.csv" ;
    schema1:description "La cazuela de pescado es un plato típico de la costa ecuatoriana también se la puede hacer de otros mariscos y siempre lleva plátano que es el ingrediente universal de la cocina ecuatoriana"^^xsd:string ;
