<http://example.org/recipes/Drink/50> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "El jugo de naranjilla, es una bebida tradicional y muy popular en los hogares ecuatorianos. Es refrescante y fácil de preparar. El sabor agridulce de la fruta le aporta a este jugo muchas propiedades y es una opción estupenda para calmar la sed."^^xsd:string ;
