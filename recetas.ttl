<http://example.org/recipes/Drink/52> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "La limonada es un refresco muy popular en Ecuador para atenuar el calor y la sed predominantes en distintas épocas del año. Esta receta es rápida y efectiva porque todos los ingredientes van a la licuadora."^^xsd:string ;
    schema1:name "Limonada"^^xsd:string ;
    schema1:recipeIngredient """2 limones cortados en cubos y sin semillas
8 tazas de agua fría
1 taza de azúcar
Hielo al gusto
Rodajas de limón
Hojas de menta o hierba buena"""^^xsd:string ;
    schema1:recipeYield 5 .

<http://example.org/recipes/Drink/53> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "La limonada de mango es un delicioso refresco que se prepara con una de las frutas tropicales más populares en Ecuador, el mango, junto con limón, azúcar y agua."^^xsd:string ;
    schema1:name "Limonada de Mango"^^xsd:string ;
    schema1:recipeIngredient """3 mangos medianos cortados en trozos
1 taza de jugo de limón
½ taza de azúcar o miel de abeja
4 tazas de agua fría
Hielo al gusto
Rodajas de limón
Hojas de menta o hierba buena"""^^xsd:string ;
    schema1:recipeYield 5 .

<http://example.org/recipes/Drink/54> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "El morocho es una bebida típica de Guayaquil de singular aroma y exquisito sabor que se ha popularizado en todo Ecuador. Se elabora con maíz morocho, leche, panela y canela y se suele servir con pan de yuca."^^xsd:string ;
    schema1:name "Morocho"^^xsd:string ;
    schema1:recipeIngredient """2 tazas granos de maíz morocho partido
6 tazas de agua 
8 tazas de leche
4 palitos de canela
½ taza de azúcar o panela rallada
½ taza de pasas
Canela molida"""^^xsd:string ;
    schema1:recipeYield 5 .

<http://example.org/recipes/Drink/55> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "Esta es la bebida clásica por excelencia de Guayaquil, de sabor exquisito y elaborada con maíz morocho se ha vuelvo famosa en todo el país."^^xsd:string ;
    schema1:name "Morocho de maiz"^^xsd:string ;
    schema1:recipeIngredient """2 tazas granos de maíz morocho partido
1 ½ litro de leche
1 taza de azúcar morena
1 litro de agua
8 tazas de leche
3 ramas de canela
Canela molida para decorar"""^^xsd:string ;
    schema1:recipeYield 10 .

<http://example.org/recipes/Drink/56> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "Refrescante bebida a base de naranjilas. Con un ligero toque de vainilla. Se sirve bien fria."^^xsd:string ;
