    schema1:recipeYield 8 .

<http://example.org/recipes/Entrance/68> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Entrance.csv" ;
    schema1:description "El maduro lampreado se consume en gran parte de la costa ecuatoriana (Manabí, Esmeraldas, Guayas y Los Ríos) y es considerado una delicia por los turistas. La preparación del maduro lampreado es muy fácil y sabrosa."^^xsd:string ;
