<http://example.org/recipes/Soup/67> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Soup.csv" ;
    schema1:description "La deliciosa sopa de lentejas es un plato muy nutritivo y fácil de elaborar. Aunque es tan popular, en esta receta le daremos el toque ecuatoriano, por lo que te invitamos a disfrutarla será del agrado de todos."^^xsd:string ;
