Orégano"""^^xsd:string,
        "comino y sal al gusto"^^xsd:string ;
    schema1:recipeYield 8 .

<http://example.org/recipes/Soup/13> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Soup.csv" ;
    schema1:description "El Caldo de Manguera es un plato guayaquileño con mucha tradición. Se prepara con la tripa del cerdo."^^xsd:string ;
    schema1:name "Caldo de manguera"^^xsd:string ;
    schema1:recipeIngredient """Menudencias (vísceras)  de 1 chancho pequeño/mediano
