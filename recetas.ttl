<http://example.org/recipes/Drink/6> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "En Ecuador, el taxo se cultiva en la serranía su cultivo se encuentra asociado con los árboles de capulí o con los de tomate árbol."^^xsd:string ;
