<http://example.org/recipes/Entrance/79> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Entrance.csv" ;
    schema1:description "La receta de la salsa de chocho es un acompañante perfecto con un sabor exquisito para degustarla en diversos platos."^^xsd:string ;
