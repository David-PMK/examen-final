    schema1:recipeYield 12 .

<http://example.org/recipes/Entrance/80> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Entrance.csv" ;
    schema1:description "El seco es un guiso tradicional de los hogares ecuatorianos, se prepara con todo tipo de carnes siendo en este caso un seco con carne de gallina."^^xsd:string ;
