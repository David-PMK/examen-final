<http://example.org/recipes/Entrance/60> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Entrance.csv" ;
    schema1:description "Las humitas son un plato típico de la región andina de Ecuador y se suelen servir con café en la tarde o para el desayuno, aunque son deliciosas a cualquier hora. Las humitas son pastelitos envueltos que se preparan con choclos o maíz tierno y queso."^^xsd:string ;
    schema1:name "Humitas"^^xsd:string ;
    schema1:recipeIngredient """6 o 7 mazorcas de choclos o maíz tierno con las hojas
3 tazas de queso rallado o desmenuzado
1 taza de cebolla picada finamente
1 cucharadita de semillas de cilantro en polvo
2 dientes de ajo machacados
¼ taza de crema líquida (o nata líquida)
2 huevos
1 cucharadita de sal"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Entrance/61> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Entrance.csv" ;
    schema1:description "Las humitas son un plato característico de Ecuador. Compuesto a base de choclos tiernos. Toda una exquisitez."^^xsd:string ;
