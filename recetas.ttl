1 cerveza
1 cucharada de sal
Pimienta al gusto"""^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Main_Dish/21> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Main_Dish.csv" ;
