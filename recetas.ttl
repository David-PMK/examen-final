<http://example.org/recipes/Main_Dish/34> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Main_Dish.csv" ;
    schema1:description "Esta deliciosa receta de pescado en crema te exaltará los sentidos, ya que forma parte de la variedad gastronómica que nos ofrecen los pueblos de la costa ecuatoriana. Te animamos a que la prepares y te luzcas en esta ocasión."^^xsd:string ;
