<http://example.org/recipes/Drink/34> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "La Horchata de ajonjoli es bebida rica y refrescante. Se sirve con hielo picadito y un toque de vainilla."^^xsd:string ;
    schema1:name "Horchata de ajonjolí"^^xsd:string ;
