<http://example.org/recipes/Soup/27> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Soup.csv" ;
    schema1:description "El zapallo, también conocido como auyama, es consumido en toda Latinoamérica, especialmente en la región andina de Ecuador. Esta receta de crema de zapallo es fácil de preparar y es ideal para los días lluviosos."^^xsd:string ;
    schema1:name "Crema de Zapallo"^^xsd:string ;
    schema1:recipeIngredient """1 zapallo de buen tamaño
3 cucharadas de aceite
1 cebolla 
3 dientes de ajo machacados
1 cucharadita de comino molido
4 tomates
6 tazas de caldo de pollo o de verduras
Sal y pimienta al gusto"""^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Soup/28> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Soup.csv" ;
    schema1:description "Delicioso Encebollado a base de cebollas y vegetales. Se puede acompañar con chifles o tostados."^^xsd:string ;
