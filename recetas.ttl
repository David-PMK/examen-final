<http://example.org/recipes/Soup/37> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Soup.csv" ;
    schema1:description "El locro es una sopa espesa, muy parecido a un guiso, muy popular en Sudamérica. En Ecuador, se prepara diferentes variaciones del locro de papas. En esta receta, la preparación es con habas, las cuales son muy populares en la Sierra ecuatoriana."^^xsd:string ;
    schema1:name "Locro de Habas"^^xsd:string ;
    schema1:recipeIngredient """4 tazas de habas peladas
2 cucharadas de aceite 
4 dientes de ajo machacados
1 cebolla blanca cortada en cubos
2 tomates pelados"""^^xsd:string,
        """sin semillas y cortados en cubos
½ cucharada de comino molido
½ cucharadita de achiote molido
1 cucharadita de chile molido o ají en polvo
3 papas peladas y cortadas en cubos
6 tazas de agua o caldo de pollo
½ taza de leche
3 huevos ligeramente batidos
1½ tazas de queso desmenuzado
3 cucharadas de cilantro finamente cortado
Sal al gusto"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Soup/38> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Soup.csv" ;
    schema1:description "Rico y nutritivo locro de nabo y vegetales. Tradicional de Ecuador. Se sirve con un poco de oregano molido."^^xsd:string ;
