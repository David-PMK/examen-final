2 dientes de ajo
3 tazas de leche de coco
1 cucharada de perejil
1 cucharada de culantro
Sal"""^^xsd:string,
        "pimienta y comino c/n"^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Main_Dish/30> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Main_Dish.csv" ;
