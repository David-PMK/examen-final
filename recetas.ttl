<http://example.org/recipes/Main_Dish/76> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Main_Dish.csv" ;
    schema1:description "La menestra de lentejas es un plato típico ecuatoriano que se prepara cocinando las lentejas con cebolla, pimiento, tomate, ajo, comino y cilantro. Las menestras son algo típico de la Costa en Ecuador, pero se puede encontrar en la casi todas las ciudades del país. El nombre completo de este plato es arroz con menestra de lentejas y carne asada"^^xsd:string ;
    schema1:name "Menestra de Lentejas"^^xsd:string ;
    schema1:recipeIngredient """3 cucharadas de aceite
1 cebolla colorada cortada en cubos pequeños
1 pimiento verde cortado en cubos pequeños
3 tomates cortados en cubos pequeños
6 dientes de ajo machacados
2 cucharaditas de comino molido
1 cucharadita de achiote molido
4 cucharadas de cilantro finamente cortado
7 tazas de agua
½ kilo de lentejas lavadas 
Sal al gusto"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Main_Dish/77> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Main_Dish.csv" ;
