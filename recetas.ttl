<http://example.org/recipes/Drink/14> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "El capuchino es muy consumido en el Ecuador principalmente por personas que trabajan en oficinas."^^xsd:string ;
