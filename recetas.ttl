Sal"""^^xsd:string,
        "pimienta c/n"^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Main_Dish/79> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Main_Dish.csv" ;
    schema1:description "El pastel de carne es un plato cuyo principal ingrediente es la carne(carne molida de vaca, jamón, tocino) y pan molido con algunas especias. Es fácil de preparar y se puede comer a cualquier hora del día."^^xsd:string ;
    schema1:name "Pastel de carne"^^xsd:string ;
