<http://example.org/recipes/Main_Dish/24> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Main_Dish.csv" ;
    schema1:description "El tamarindo es cultivado en la provincia de Manabi, pero en todo el país es consumido ya sea en jugos o para darle un realce de sabor a los platos fuertes como el cerdo en salsa de tamarindo."^^xsd:string ;
    schema1:name "Cerdo en salsa de tamarindo"^^xsd:string ;
    schema1:recipeIngredient """3 lb de lomo de cerdo o pernil de cerdo
½ lb de pulpa de tamarindo
½ taza de salsa de tomate
1 taza de caldo de res o pollo
1 zanahoria amarilla
2 dientes de ajo
1 rama de romero
2 cucharadas de azúcar o miel
Aceite de oliva o de aguacate
Sal y pimienta al gusto"""^^xsd:string ;
    schema1:recipeYield 8 .

<http://example.org/recipes/Main_Dish/25> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Main_Dish.csv" ;
    schema1:description "El tamarindo es un fruto consumido en todo el país ya sea en jugos, coladas o para realzar el sabor de platos fuertes como el de esta receta que presentamos aquí."^^xsd:string ;
