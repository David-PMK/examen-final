<http://example.org/recipes/Soup/39> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Soup.csv" ;
    schema1:description "El locro de zapallo es una sopa muy espesa, la cual se puede combinar con papa y queso, es muy delicioso y se puede degustar en familia."^^xsd:string ;
    schema1:name "Locro de zapallo"^^xsd:string ;
