<http://example.org/recipes/Drink/13> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "El canelazo es una bebida ecuatoriana tradicional de la Sierra, se prepara mezclando agua con canela, azúcar y aguardiente. Es ideal para las noches frías o cuando llueve."^^xsd:string ;
    schema1:name "Canelazo"^^xsd:string ;
