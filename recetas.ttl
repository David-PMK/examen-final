<http://example.org/recipes/Soup/86> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Soup.csv" ;
    schema1:description "El yahuarlocro es una de las preparaciones más famosas de Ecuador y su nombre nace de las palabras Yahuar (sangre) y locro (sopa o caldo). Este plato es preparado a nivel nacional, aunque es más popular en Guayabamba, ciudad cercana a la capital ecuatoriana."^^xsd:string ;
