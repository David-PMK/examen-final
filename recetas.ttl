    schema1:recipeIngredient """4 tazas de leche
½ taza de chocolate
2 ramas de canela
4 pepitas de pimienta dulce
Azúcar al gusto"""^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Drink/11> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "Incorporar espinaca a nuestra dieta es siempre una opción nutritiva y saludable, este batido se lo encuentra en puestos de mercados populares principalmente."^^xsd:string ;
