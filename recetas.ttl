@prefix dct: <http://purl.org/dc/terms/> .
@prefix schema1: <http://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/recipes/Confectionery/1> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Los alfajores de manjar es uno de los dulces favoritos de las familias ecuatorianas, puedes encontrar los mejores alfajores en la provincia de Manabi."^^xsd:string ;
    schema1:name "Alfajores"^^xsd:string ;
    schema1:recipeIngredient """1 taza de harina
4 cucharadas de maicena
½ taza de margarina
2 yemas de huevo
½ taza de azúcar impalpable
½ cucharadita de polvo de hornear
1 cucharadita de esencia vainilla"""^^xsd:string ;
    schema1:recipeYield 10 .

<http://example.org/recipes/Confectionery/10> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Exquisito postre de chocolate caliente. Con un toque único y tradicional de Ecuador al acompañarlo con queso."^^xsd:string ;
    schema1:name "Chocolate caliente con queso"^^xsd:string ;
    schema1:recipeIngredient """4 ½ tazas de leche
1 tableta de chocolate
5 clavitos de olor
Azúcar al gusto
Canela en trozos"""^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Confectionery/11> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Las cocadas son un dulce clásico de Ecuador. Manjar famoso que lleva al coco como su ingrediente estrella."^^xsd:string ;
    schema1:name "Cocadas ecuatorianas"^^xsd:string ;
    schema1:recipeIngredient """1 coco entero rallado
400 gr de azúcar
4 yemas de huevo
2 tazas de leche
25 gr de mantequilla"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Confectionery/12> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Las cocadas son uno de los clásicos dulces de coco de la ciudad ecuatoriana de Esmeraldas. Es un manjar de panela seca con textura comprometedora del coco que se mete hasta el infinito del gusto."^^xsd:string ;
    schema1:name "Cocadas Esmeraldeñas"^^xsd:string ;
    schema1:recipeIngredient """1 coco rallado 
2 tazas de leche 
½ kilo de panela rallada
¼ kilo de azúcar 
4 yemas de huevo 
2 onzas de mantequilla 
1 cucharada de jugo de limón"""^^xsd:string ;
    schema1:recipeYield 8 .

<http://example.org/recipes/Confectionery/13> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El come y bebe es una ensalada de frutas ecuatoriana muy fácil de preparar que contiene frutas exóticas y muy frescas, como papaya, banano, piña, mango, guineos maduros, moras, etc., acompañadas con zumo de naranja. Esta mezcla de trozos enteros de frutas y zumo de naranja, puede comerse y beberse a la vez, de ahí el nombre peculiar de este postre."^^xsd:string ;
    schema1:name "Come y Bebe"^^xsd:string ;
    schema1:recipeIngredient """Jugo de 10 naranjas
1 papaya grande y madura
1 piña pelada 
6 bananos o guineos maduros
6 mangos maduros
Azúcar o miel al gusto"""^^xsd:string ;
    schema1:recipeYield 8 .

<http://example.org/recipes/Confectionery/14> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "La chirimoya es una planta comestible originaria del sur del Ecuador, donde crece de forma silvestre, tiene un exquisito sabor que se expresa muy bien en esta crema."^^xsd:string ;
    schema1:name "Crema de chirimoya"^^xsd:string ;
    schema1:recipeIngredient """750 gr de pulpa de chirimoya
1 taza azúcar
1 lata de leche condensada
1 taza de agua
3 sobres de gelatina sin sabor"""^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Confectionery/15> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "La chirimoya es originaria de la parte sur del Ecuador, en la provincia de Loja, donde se encuentra formando densos bosques silvestres. La crema de chirimoyas es un postre que tiene un exquisito sabor y es muy fácil de realizar."^^xsd:string ;
    schema1:name "Crema de chirimoyas"^^xsd:string ;
    schema1:recipeIngredient """900 gr de pulpa de chirimoya
1 taza azúcar
4 sobres de gelatina sin sabor
1 lata de leche evaporada
1 taza de agua"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Confectionery/16> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El babaco es una fruta original de la provincia de Loja, en Ecuador. Es un híbrido natural resultante del cruce entre toronche y chamburo. El dulce de babaco es una especie de almíbar hecho con la fruta, azúcar, agua y un poco de canela. Existen variantes de la receta donde añaden ron, cachaca o aguardiente."^^xsd:string ;
    schema1:name "Dulce de Babaco"^^xsd:string ;
    schema1:recipeIngredient """1 babaco maduro
2 tazas de azúcar
1 rama de canela
2 clavos de olor
Jugo de 1 limón
Agua"""^^xsd:string ;
    schema1:recipeYield 10 .

<http://example.org/recipes/Confectionery/17> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El babaco es una fruta originaria del Ecuador. En esta receta se preparará una especie de almíbar hecho con la fruta, azúcar, agua y  canela."^^xsd:string ;
    schema1:name "Dulce de babacos"^^xsd:string ;
    schema1:recipeIngredient """1 babaco maduro
2 tazas de azúcar
1 rama de canela
2 clavos de olor
Jugo de 1 limón
2 tazas de agua"""^^xsd:string ;
    schema1:recipeYield 2 .

<http://example.org/recipes/Confectionery/18> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Suculentos higos acaramelados. Con un toque autentico de Ecuador del queso y la canela."^^xsd:string ;
    schema1:name "Dulce de higo con queso"^^xsd:string ;
    schema1:recipeIngredient """5 higos
1 taza de queso
3 ramitas de canela
Clavo de olor
1 taza de panela"""^^xsd:string ;
    schema1:recipeYield 3 .

<http://example.org/recipes/Confectionery/19> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El dulce de higos es uno de esos postres que representan la esencia de Ecuador, son deliciosos y sencillos. El proceso para preparar los higos es un poco largo, tarda casi tres días, pero vale la pena la espera, es el toque ideal para el final a una buena comida."^^xsd:string ;
    schema1:name "Dulce de higos"^^xsd:string ;
    schema1:recipeIngredient """20 higos lavados maduros pero firmes
1 pizca de bicarbonato
1 kilo de panela o piloncillo
Canela"""^^xsd:string,
        """clavo de olor y otras especias
Agua"""^^xsd:string ;
    schema1:recipeYield 10 .

<http://example.org/recipes/Confectionery/2> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Ricos dulces de alfajores rellenos con manjar o dulce de leche. Tradicionales de Ecuador."^^xsd:string ;
    schema1:name "Alfajores rellenos de manjar"^^xsd:string ;
    schema1:recipeIngredient """Para la masa
375 gr de harina
375 gr  de maicena
250 gr de azúcar glas
1 huevo
1 tapita de limón
375 de margarina"""^^xsd:string ;
    schema1:recipeYield 20 .

<http://example.org/recipes/Confectionery/20> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El espectacular dulce de leche o manjar de leche, como es típicamente conocido en Ecuador, es  un postre muy tradicional en latinoamérica. Es un postre que le encanta a todos y se consume como parte de otras delicias o simplemente solo. Anímate a prepararlo."^^xsd:string ;
    schema1:name "Dulce de leche"^^xsd:string ;
    schema1:recipeIngredient """1 litro de leche entera
3 tazas	de azúcar o panela molida
100 gr de mantequilla
2 cucharadas de esencia de vainilla"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Confectionery/21> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El sambo es un fruto que en el país se desarrolla de forma silvestre en laderas y quebradas, principalmente de las provincias la sierra, en dónde se elaboran sopas, coladas y dulces."^^xsd:string ;
    schema1:name "Dulce de sambo"^^xsd:string ;
    schema1:recipeIngredient """1 sambo maduro de 2 kg
½ lb de nueces o almendras partidas y peladas
1 lb de azúcar morena
Ralladura de naranja
Clavos de olor
Canela"""^^xsd:string ;
    schema1:recipeYield 12 .

<http://example.org/recipes/Confectionery/22> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El sambo es un fruto tradicional del Ecuador, crece de forma silvestre en toda la región de la sierra siendo el ingrediente principal de muchas compotas, sopas y dulces exquisitos."^^xsd:string ;
    schema1:name "Dulce de sambos"^^xsd:string ;
    schema1:recipeIngredient """1 kg de sambos maduros
400 gr de nueces
400 gr de azúcar morena
Ralladura de una naranja
3 clavos de olor
Una rama de canela"""^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Confectionery/23> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El dulce de zapallo, también conocido como zapallo con miel de panela, es un postre tradicional ecuatoriano preparado con zapallo (calabaza o auyama), panela o piloncillo y especias. Este delicioso postre usa ingredientes sencillos y es muy fácil de preparar. Se sirve acompañado con un trozo de quesillo o queso."^^xsd:string ;
    schema1:name "Dulce de Zapallo"^^xsd:string ;
    schema1:recipeIngredient """1 zapallo de casi 1 kilo
½ kilo de panela o piloncillo cortado en trozos
5 rajas de canela
5 clavos de olor
3 granos de pimienta dulce
3 tazas de agua"""^^xsd:string ;
    schema1:recipeYield 8 .

<http://example.org/recipes/Confectionery/24> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Los famosos Dulces de los Reyes, son un exquisito postre que consiste de un biscocho esponjoso cubierto con mermelada y manjar de leche. Es una de los dulces típicos y que forma parte de las tradiciones gastronómicas del Ecuador."^^xsd:string ;
    schema1:name "Dulces de los reyes"^^xsd:string ;
    schema1:recipeIngredient """900 gr de harina
2 ½ litros de leche
4 huevos
200 gr de mantequilla
3 ½ tazas de azúcar
1 cucharada de esencia de vainilla
1 cucharada de polvo de hornear
1 piña mediana pelada"""^^xsd:string ;
    schema1:recipeYield 12 .

<http://example.org/recipes/Confectionery/25> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Los envueltos de maqueño o plátano maduro es muy popular en Ecuador y su consumo se ha generalizado principalmente gracias a los migrantes colombianos que han llegado al país."^^xsd:string ;
    schema1:name "Envueltos de maqueño"^^xsd:string ;
    schema1:recipeIngredient """4 plátanos maqueño rallados
½ lb de queso
½ taza de azúcar
½ taza de pasas enharinadas
2 cucharaditas de polvo de hornear
125 gr de mantequilla
3 huevos
½ taza de maicena
Hojas de achira o de plátano
Vainilla al gusto
1 copa de licor anisado"""^^xsd:string ;
    schema1:recipeYield 10 .

<http://example.org/recipes/Confectionery/26> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Las espumillas, también conocido como suspiritos o suspiros son un dulce muy popular en Ecuador. Se trata de una especie de espuma cremosa tipo merengue preparada con pulpa de guayaba, claras de huevo y azúcar. Se puede colorear, de manera que se encuentra en diversos colores."^^xsd:string ;
    schema1:name "Espumillas"^^xsd:string ;
    schema1:recipeIngredient """8 guayabas maduras 
1½ tazas de azúcar
2 claras de huevo
Arrope o salsa de mora 
Grajeas y/o coco rallado"""^^xsd:string ;
    schema1:recipeYield 8 .

<http://example.org/recipes/Confectionery/27> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El flan de coco es un postre muy popular en Ecuador que se prepara con coco rallado, leche condensada, leche, huevos y azúcar. Este flan es un postre fácil de preparar que todos disfrutan."^^xsd:string ;
    schema1:name "Flan de Coco"^^xsd:string ;
    schema1:recipeIngredient """1¼ taza de azúcar
¼ taza de agua
2 tazas de leche condensada
2 tazas de leche
4 huevos
1 taza de coco rallado"""^^xsd:string ;
    schema1:recipeYield 10 .

<http://example.org/recipes/Confectionery/28> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Las tradicionales galletas de coco rallado, son uno de los postres más apetecidos para compartir en las  meriendas vespertinas. Estos deliciosos bocadillos dulces tienen un sabor muy especial, característico del coco y pueden disfrutarse acompañadas de helado o con una taza de café o chocolate caliente."^^xsd:string ;
    schema1:name "Galletas de coco"^^xsd:string ;
    schema1:recipeIngredient """200 gr de coco rallado
100 gr de mantequilla
220 gr de azúcar
100 gr de harina
½ cucharadita de polvo de hornear
1 huevo"""^^xsd:string ;
    schema1:recipeYield 8 .

<http://example.org/recipes/Confectionery/29> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Las guaguas son un pan muy tradicional de Ecuador preparadas especialmente para celebrar el día de los difuntos."^^xsd:string ;
    schema1:name "Guaguas de pan"^^xsd:string ;
    schema1:recipeIngredient """5 gr de levadura seca
1 cucharada de azúcar
1 taza leche tibia
1 kg harina
4 huevos
200 gramos mantequilla
1 taza azúcar
Esencia de vainilla
1 pizca de sal
Mermelada a elección para rellenar"""^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Confectionery/3> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El aplanchado es un postre clásico de la Sierra, en el Ecuador. Este dulce tradicional se realiza con hojaldre y azúcar glasé."^^xsd:string ;
    schema1:name "Aplanchado"^^xsd:string ;
    schema1:recipeIngredient """500 gr de harina de trigo
50 gr de mantequilla
1 huevo
2 yemas de huevo
2 tazas de azúcar impalpable
½ taza de azúcar
2 cucharaditas de polvo de hornear
½ vaso de jugo de naranja
¼ vaso de aceite
Esencia de vainilla"""^^xsd:string ;
    schema1:recipeYield 3 .

<http://example.org/recipes/Confectionery/30> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Deliciosos pancitos denominados guayuas de pan. Decorados alegremente. Muy consumido en Ecuador."^^xsd:string ;
    schema1:name "Guayuas de pan"^^xsd:string ;
    schema1:recipeIngredient """1 cucharada de levadura instantánea
½ taza de leche tibia
½ taza de azúcar
2 cucharaditas de sal
4 tazas de harina
1 barra de mantequilla
4 huevos
1 cucharadita de esencia de vainilla
Ralladura de naranja al gusto
2 yemas de huevo
Glaseado de colores
Pasas opcional
Para relleno:
Chocolate"""^^xsd:string,
        "dulce de leche o mermelada"^^xsd:string ;
    schema1:recipeYield 12 .

<http://example.org/recipes/Confectionery/31> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Los deliciosos helados de paila, son un tradición gastronómica de Ecuador. Su elaboración es de manera artesanal, implementándose técnicas que se han transmitido de generación en generación. Sus sabores intensos a frutas, sus colores y cremosidad, los hacen una opción exquisita para el disfrute de todos."^^xsd:string ;
    schema1:name "Helado de paila"^^xsd:string ;
    schema1:recipeIngredient """4 litros de jugo de mora u otra frutilla
6 tazas de azúcar
Hielo
Paja
Sal marina en granos"""^^xsd:string ;
    schema1:recipeYield 8 .

<http://example.org/recipes/Confectionery/32> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Rico postre frió preparado en paila con la ayuda de hielo.  Un autentico Helado Ecuatoriano."^^xsd:string ;
    schema1:name "Helado de paila de mora y mango ecuatoriano"^^xsd:string ;
    schema1:recipeIngredient """5 lb de sal en grano
Una paila pequeña
Pala de madera
Un yute para poner debajo de la paila o bolsa plástica
Un recipiente grande para colocar hielo"""^^xsd:string,
        """Una bolsa grande de hielo picado
1 mango grande  picado en trozos pequeños
1 taza de mora
200 gr de azúcar
½ tasa de crema de leche fria
1"""^^xsd:string ;
    schema1:recipeYield 3 .

<http://example.org/recipes/Confectionery/33> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El helado frito está ganando bastante popularidad en Ecuador, especialmente en las ciudades grandes como Quito y Guayaquil"^^xsd:string ;
    schema1:name "Helado frito"^^xsd:string ;
    schema1:recipeIngredient """2 bolas de helado de tu sabor favorito
4 rebanadas de pan de molde blanco sin corteza 
1 taza y media de leche de vaca"""^^xsd:string,
        """almendras o la que prefieras.
1 taza y media de harina de trigo
1 huevo
Aceite para freír
Sirope de chocolate"""^^xsd:string,
        "miel o nata (opcional)"^^xsd:string,
        "soja"^^xsd:string ;
    schema1:recipeYield 2 .

<http://example.org/recipes/Confectionery/34> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Los ricos helados de Salcedo, son uno de los postres favoritos de niños y adultos en Ecuador. Y si eres de los que le encantan los helados, estos son una deliciosa alternativa si quieres disfrutar del sabor de las frutas naturales. Tradicionalmente se hacen a base de capas multicolores que representan los diferentes sabores."^^xsd:string ;
    schema1:name "Helados de salcedo"^^xsd:string ;
    schema1:recipeIngredient "Jugo de frutas frescas (moras"^^xsd:string,
        """guanabana)
150 gr de tazas de leche en polvo
200 gr de crema de leche
120 gr de azúcar
30 gr de glucosa
2 tazas de agua"""^^xsd:string,
        "naranjilla"^^xsd:string,
        "taxo"^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Confectionery/35> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "La isla flotante es un postre clásico, suave y delicioso que puede ser degustado entre todos los miembros de la familia."^^xsd:string ;
    schema1:name "Isla flotante"^^xsd:string ;
    schema1:recipeIngredient """4 huevos
4 cucharadas de mermelada de frambuesa
½ litro de leche
1 cucharadita de maicena
½ cucharadita vainilla
Azúcar al gusto"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Confectionery/36> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "La javishca es una clásica bebida caliente de Ecuador, sus ingredientes principales son el zapallo y la  leche y es la bebida preferida de la región serrana en épocas de cosecha."^^xsd:string ;
    schema1:name "Javishca de zapallo"^^xsd:string ;
    schema1:recipeIngredient """1 zapallo mediano maduro
1 litro leche
2 tazas de panela
5 estrellas de anís estrellado
2 ramas de canela"""^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Confectionery/37> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Los deliciosos quimbolitos, son pequeños bizcochos elaborados con una masa dulce de harina de maíz blanco, el toque salado de queso y unas riquísimas pasas. Este exquisito manjar se cocina al vapor en hojas de achira y pueden consumirse acompañadas de una deliciosa taza de café."^^xsd:string ;
    schema1:name "Kimbolitos"^^xsd:string ;
    schema1:recipeIngredient """250 gr.	de harina de maíz blanco
500 gr de queso fresco rallado
9 huevos
1 taza de azúcar
200 gr de mantequilla sin sal
250 gr.	manteca de chancho
½ cucharadita de ralladura de limón
2 cucharadas de ron anisado
½ tazas de pasas
1 cucharada de esencia de vainilla
20 hojas de achira"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Confectionery/38> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Delicioso dulce característico de Ecuador. Muy suave compuesto por leche y azúcar. Con un toque de canela."^^xsd:string ;
    schema1:name "Manjar blanco ecuatoriano"^^xsd:string ;
    schema1:recipeIngredient """1 lts de leche
1 taza de azúcar
Canela al gusto"""^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Confectionery/39> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Las medias lunas son un delicioso postre que puedes encontrar en los restaurantes ecuatorianos y que son muy fáciles de preparar en tu hogar para que te luzcas con tus invitados."^^xsd:string ;
    schema1:name "Medias Lunas de Nuez"^^xsd:string ;
    schema1:recipeIngredient """1 taza de mantequilla 
½ taza de azúcar glass 
½ cucharadita de sal 
2 tazas de nueces picadas 
1 cucharadita de extracto de vainilla 
2 tazas de harina de trigo"""^^xsd:string ;
    schema1:recipeYield 12 .

<http://example.org/recipes/Confectionery/4> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El aplanchado es un dulce tradicional de la Sierra, en el Ecuador. Este postre consiste en una capa de masa de hojaldre cubierta por una capa de azúcar glasé."^^xsd:string ;
    schema1:name "Aplanchados"^^xsd:string ;
    schema1:recipeIngredient """1½ cucharaditas de polvo de hornear
½ kilo de harina de trigo
1½ cucharadita de esencia de vainilla
5 cucharadas de mantequilla
1 huevo entero
2 yemas de huevo
½ taza de azúcar 
¼ de taza de aceite
1 pizca de sal
4 cucharadas de jugo de naranja
2 tazas de azúcar impalpable"""^^xsd:string ;
    schema1:recipeYield 10 .

<http://example.org/recipes/Confectionery/40> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "La piña es una de las frutas exóticas muy común de Ecuador, con la cual se prepara un gran número de postres como la mermelada de piña. Para preparar este dulce, además de la piña, se utiliza otros ingredientes como azúcar o panela rallada, canela, clavos de olor, cardamomo, cedrón y zumo de limón."^^xsd:string ;
    schema1:name "Mermelada de Piña"^^xsd:string ;
    schema1:recipeIngredient """1 piña madura entera
½ taza de agua
½ taza de azúcar (o panela rallada)
1 rajita de canela
3 clavos de olor
Jugo de un limón"""^^xsd:string ;
    schema1:recipeYield 10 .

<http://example.org/recipes/Confectionery/41> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "La mermelada de tomate de árbol o tamarillo, es un exquisito postre muy fácil de preparar. Esta fruta está llena de vitaminas y propiedades muy saludables, por lo que disfrutarla de esta forma deleitará su paladar. Es común acompañarla con galletas o pan."^^xsd:string ;
    schema1:name "Mermelada de tomate de Árbol"^^xsd:string ;
    schema1:recipeIngredient """½ kg de tomates de palo bien maduros
250 gr de azúcar
1 limón"""^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Confectionery/42> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Rico postre característico de Ecuador. Generalmente se come en forma de orejitas. Endulzado con canela y azúcar."^^xsd:string ;
    schema1:name "Milhojas y orejitas ecuatorianas"^^xsd:string ;
    schema1:recipeIngredient """1 kg  hojaldrina
1  huevo
Azucar al gusto
Canela al gusto"""^^xsd:string ;
    schema1:recipeYield 30 .

<http://example.org/recipes/Confectionery/43> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Delicioso dulce tradicional de Ecuador. Compuesto por morocho dulce y esencias que le dan ese toque caracteristico."^^xsd:string ;
    schema1:name "Morocho dulce ecuatoriano"^^xsd:string ;
    schema1:recipeIngredient """1 taza de morocho (remojado)
4 tazas de agua
4 tazas de leche entera
½ taza de azúcar o de leche condensada
6 bolitas de pimienta dulce
4 clavos de olor
½ taza de pasas o al gusto"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Confectionery/44> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El mousse de dulce de leche es un postre que podrás realizar en poco tiempo y le va a encantar a los más pequeños de la casa. En Ecuador al dulce de leche se lo conoce también como manjar de leche"^^xsd:string ;
    schema1:name "Mousse de dulce de leche"^^xsd:string ;
    schema1:recipeIngredient """4 claras de huevo
½ lb de azúcar
1 taza de crema de leche (250 ml)
1 taza de dulce de leche (250 ml)
Galletas de vainilla"""^^xsd:string,
        "frutos secos tostados o praliné"^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Confectionery/45> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Este rico y delicado postre se elabora a base del Taxo, una fruta deliciosa y con múltiples propiedades. Es típica del Ecuador y tiene gran sabor, muy nutritiva y saludable. Sencillamente una alternativa deliciosa de aprovechar las bondades de este fruto. Anímate."^^xsd:string ;
    schema1:name "Mousse de taxo"^^xsd:string ;
    schema1:recipeIngredient """1 taza de pulpa de taxo
2 claras de huevo
1 lata de leche evaporada
½ taza de leche condensada
1 sobre de gelatina sin sabor
¼ taza de agua"""^^xsd:string ;
    schema1:recipeYield 8 .

<http://example.org/recipes/Confectionery/46> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "En Ecuador el consumo de manzana es bastante alto e incluso su producción local no alcanza para cubrir la demanda, las personas la consumen generalmente frescas pero también en postres como el muffins de manzana y canela"^^xsd:string ;
    schema1:name "Muffins de manzana y canela"^^xsd:string ;
    schema1:recipeIngredient """½ lb de harina
½ taza de azúcar
1 cucharadita de polvo de hornear
½ cucharadita de sal
1 cucharadita de canela molida
1 huevo
1 taza de leche
2 manzanas peladas y ralladas
1/3 taza de azúcar morena
1 cucharada de harina
2 cucharadas de mantequilla
Aceite de oliva o manteca"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Confectionery/47> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "La natilla o mazmorra de choclo es un platillo muy popular en la provincia de Manabi y se hace con el choclo cuando está endureciendo,"^^xsd:string ;
    schema1:name "Natilla o mazamorra de choclo"^^xsd:string ;
    schema1:recipeIngredient """4 mazorcas de choclo duro
1 litro de leche
3 o 4 astillas de canela
Clavo de olor
Azúcar al gusto
1 cucharadita de esencia de vainilla
Canela en polvo para decorar"""^^xsd:string ;
    schema1:recipeYield 10 .

<http://example.org/recipes/Confectionery/48> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El postre \"Negro en camisa\" es un Mousse de chocolate que está ganando popularidad en Ecuador gracias a los migrantes venezolanos que han llegado al territorio."^^xsd:string ;
    schema1:name "Negro en camisa"^^xsd:string ;
    schema1:recipeIngredient """½ lb de chocolate en polvo (semi amargo)
½ lb de mantequilla
½ lb de azúcar
10 yemas de huevo
5 claras de huevo
½ taza de harina para repostería
2 tazas de agua
1 litro de leche
2 ramas de canela o vainilla"""^^xsd:string ;
    schema1:recipeYield 10 .

<http://example.org/recipes/Confectionery/49> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Las nogadas son dulces artesanales muy ricos y típicos de la gastronomía de Ibarra. Tradicionalmente se les puede encontrar en cajitas de sauce envueltas en papel celofán."^^xsd:string ;
    schema1:name "Nogadas"^^xsd:string ;
    schema1:recipeIngredient """1 kg de panela
2 tazas de agua
1 taza de tocte picados (nuez)
50 gr de manteca
1 huevo"""^^xsd:string ;
    schema1:recipeYield 8 .

<http://example.org/recipes/Confectionery/5> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El arroz con leche es un postre típico del Ecuador que le encanta principalmente a los niños, se sirve frío o caliente."^^xsd:string ;
    schema1:name "Arroz con leche"^^xsd:string ;
    schema1:recipeIngredient """1 taza de arroz
2 tazas de leche
½ taza de azúcar o panela
1 cucharada de vainilla
2 ramas de canela
½ lata de leche condensada o 2 huevos batidos
½ taza de pasas
5 clavos de olor
2 cucharadas de canela en polvo para espolvorear"""^^xsd:string ;
    schema1:recipeYield 10 .

<http://example.org/recipes/Confectionery/50> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Los paquetitos de maqueño o plátano maduro son un dulce muy popular en Ecuador, comparte su origen con la patria colombiana. Simples de realizar, son una delicia."^^xsd:string ;
    schema1:name "Paquetitos de maqueño"^^xsd:string ;
    schema1:recipeIngredient """4 plátanos maqueño
200 gr de queso blanco
½ taza de azúcar
125 gr de mantequilla
3 huevos
2 cucharaditas de polvo de hornear
½ taza de almidón de maíz
Hojas de achira
Esencia de vainilla
½ taza de pasas de uva"""^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Confectionery/51> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El maduro es un plátano indispensable en la cocina ecuatoriana. Esta receta de pie de maduro contrasta el sabor dulce del plátano con el salado del queso, haciendo de este postre una fabulosa combinación propia del Ecuador."^^xsd:string ;
    schema1:name "Pie de Maduro"^^xsd:string ;
    schema1:recipeIngredient """½ kilo de harina de trigo
5 cucharadas de mantequilla
2½ tazas de azúcar
5 huevos
2 cucharaditas de sal
2 tazas de azúcar panela
½ taza de agua
5 plátanos maduros cortados en cubitos
½ taza de queso blanco rallado"""^^xsd:string ;
    schema1:recipeYield 8 .

<http://example.org/recipes/Confectionery/52> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Los pristiños con miel son muy tradicionales en Ecuador para disfrutar en cualquier fecha del año, son deliciosas masitas bañadas con miel."^^xsd:string ;
    schema1:name "Pristiños"^^xsd:string ;
    schema1:recipeIngredient """2 tazas de harina
1 cucharadita de polvo de hornear
2 huevos
2 cucharada de mantequilla
1 pizca de sal
½ taza de leche
Aceite para freir 
1 ramita de canela
2 tazas de panela rayada
1 cucharada de jugo de limón
2 tazas de agua"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Confectionery/53> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Los pristiños con miel son dulces tradicionales del Ecuador, se consumen clasicamente durante las celebraciones navideñas."^^xsd:string ;
    schema1:name "Pristiños con miel"^^xsd:string ;
    schema1:recipeIngredient """2 tazas de harina
Una pizca de polvo de hornear
2 huevos
50 gr de mantequilla
100 cc de leche
1 rama de canela
2 tazas de panela
Jugo de ½ limón
2 tazas de agua
Sal
Aceite para freír"""^^xsd:string ;
    schema1:recipeYield 5 .

<http://example.org/recipes/Confectionery/54> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Las quesadillas, son bocados dulces de gran sabor, que son tradicionales en la ciudad de Quito, capital de los ecuatorianos. Esta delicia criolla suele acompañarse con helado o los famosos salpicones (jugos de fruta natural con hielo raspado)."^^xsd:string ;
    schema1:name "Quesadillas Ecuatorianas"^^xsd:string ;
    schema1:recipeIngredient """1 huevo
1 cucharadita de mantequilla
1 taza de harina de trigo
½ cucharadita de sal disuelta en 2 cucharadas de agua
4 yemas de huevo
1 taza de queso rallado
1 taza de azúcar impalpable
1 cucharada de maicena"""^^xsd:string ;
    schema1:recipeYield 10 .

<http://example.org/recipes/Confectionery/55> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "En Ecuador, especialmente en la costa, es muy común encontrar deliciosos flanes preparados con coco, piña u otras frutas. El queso de piña es una receta sencilla para preparar un delicioso flan con jugo de piña, azúcar, leche, huevos, vainilla y ron."^^xsd:string ;
    schema1:name "Queso de Piña"^^xsd:string ;
    schema1:recipeIngredient """10 moldes de flan pequeños engrasados ligeramente con mantequilla
2 tazas de azúcar
½ taza de agua
2½ tazas de jugo de piña fresca"""^^xsd:string,
        """colado y sin la espuma
1 cucharada de maicena
1 taza de leche 
10 huevos
1 cucharadita de esencia o extracto de vainilla
2 cucharadas de ron
10 rodajas de piña
Azúcar morena"""^^xsd:string ;
    schema1:recipeYield 10 .

<http://example.org/recipes/Confectionery/56> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Los quimbolitos son pasteles, propios del Ecuador y del sur de Colombia elaborados con harina de maíz, cocidos al vapor envueltos en hojas de achira."^^xsd:string ;
    schema1:name "Quimbolitos"^^xsd:string ;
    schema1:recipeIngredient """1 taza de harina de maíz
1 taza de harina de trigo
1 taza de pasas
1 lb de queso de mesa
1 cucharadita de polvo de hornear
1 taza de margarina
½ cucharadita de ralladura de limón
1 cucharadita de esencia de vainilla
1 taza de azúcar
9 yemas de huevos
4 cucharaditas de aguardiente / coñac o de ron
9 claras de huevo
Hojas de achira"""^^xsd:string ;
    schema1:recipeYield 12 .

<http://example.org/recipes/Confectionery/57> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Los tradicionales quimbolitos son pasteles dulces autoctonos del Ecuador con la particularidad de ser cocidos al vapor envueltos en hojas de la planta de achira."^^xsd:string ;
    schema1:name "Quimbolitos ecuatorianos"^^xsd:string ;
    schema1:recipeIngredient """1 taza de harina de maíz
1 taza de harina de trigo
1 taza de margarina
1 taza de azúcar
7 huevos
1 taza de pasas
450 gr de queso semi duro
½ vaso de aguardiente
Hojas de achira
1 cucharadita de polvo de hornear
Ralladura de un limón
1 cucharadita de esencia de vainilla"""^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Confectionery/58> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Las rosquitas de mantequilla, hechas al horno, son muy populares en la ciudad de Guayaquil. Estas rosquitas ecuatorianas son deliciosas con Nutella o mermeladas de fruta y van bien con un té o un café."^^xsd:string ;
    schema1:name "Rosquitas de Mantequilla"^^xsd:string ;
    schema1:recipeIngredient """3 tazas de harina de trigo 
4 yemas de huevo
4 cucharadas de mantequilla (preferiblemente sin sal)
1 pizca de sal 
1 cucharadita de polvo de hornear 
4 cucharadas de azúcar blanca
½ taza de leche fría"""^^xsd:string ;
    schema1:recipeYield 30 .

<http://example.org/recipes/Confectionery/59> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El maduro es el plátano tradicional de la gastronomía ecuatoriana, ingrediente principal de múltiples recetas, en este caso una tarda de maduro y queso. Una delicia."^^xsd:string ;
    schema1:name "Tarta de maduro"^^xsd:string ;
    schema1:recipeIngredient """500 gr de harina de trigo
5 plátanos maduros
½ taza de queso blanco
50 gr de mantequilla
2 tazas de azúcar
2 tazas de panela
5 huevos
2 cucharaditas de sal
½ taza de agua"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Confectionery/6> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Estos clásicos bollitos de harina de yuca, son un éxito simple y económico de la repostería ecuatoriana, ideales para la merienda."^^xsd:string ;
    schema1:name "Bollitos de yuca"^^xsd:string ;
    schema1:recipeIngredient """350 gr de harina de yuca
1 huevo
500 gr queso semi duro
1 taza de agua
Sal a gusto"""^^xsd:string ;
    schema1:recipeYield 5 .

<http://example.org/recipes/Confectionery/60> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "La tarta de mandarina es un postre delicioso y que podamos preparar sin demasiadas complicaciones para cualquier celebración."^^xsd:string ;
    schema1:name "Tarta de mandarinas"^^xsd:string ;
    schema1:recipeIngredient """250 gr de galletas molidas (tipo María)
3 cucharadas de mantequilla
8 mandarinas
1 taza de jugo de mandarina
¼ taza de zumo de limón
100 ml. de vino dulce
1 cucharadita de ralladura de una mandarina.
500 gr de leche condensada
4 huevos"""^^xsd:string ;
    schema1:recipeYield 8 .

<http://example.org/recipes/Confectionery/61> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El tiramisú de fresas es un postre ligero y delicioso, es el broche de oro para cualquier ocasión especial."^^xsd:string ;
    schema1:name "Tiramisú con fresas"^^xsd:string ;
    schema1:recipeIngredient """1 lb de queso mascarpone
½ taza de azúcar
3 huevos
2 tazas de café expreso
8 bizcochos
2 cucharadas de cacao en polvo
2 cucharadas de ralladura de chocolate"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Confectionery/62> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El choclo es muy popular en la gastronomía de Ecuador y la torta de choclo es una de las tantas recetas tradicionales con este alimento delicioso y nutritivo. Este postre viene bien a cualquier hora del día acompañado con una buena taza de café."^^xsd:string ;
    schema1:name "Torta de Choclo con Coco"^^xsd:string ;
    schema1:recipeIngredient """6 choclos desgranados 
5 cucharadas de mantequilla
½ taza de coco rallado
1 lata de leche condensada
1 cucharada de esencia de vainilla
2 huevos
1 cucharadita de polvo de hornear
Harina de trigo y mantequilla (para el molde)"""^^xsd:string ;
    schema1:recipeYield 10 .

<http://example.org/recipes/Confectionery/63> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Esta receta ecuatoriana de la torta de naranja es muy fácil, rica y económica de preparar. Esta torta esponjosa es ideal para compartir a la hora de la merienda acompañada de té o café."^^xsd:string ;
    schema1:name "Torta de Naranja"^^xsd:string ;
    schema1:recipeIngredient """1 taza de jugo de naranja
3 tazas de harina de trigo previamente tamizada
1 taza de azúcar
½ taza de aceite 
3 huevos
Ralladura de una naranja
2 cucharaditas de polvo para hornear"""^^xsd:string ;
    schema1:recipeYield 10 .

<http://example.org/recipes/Confectionery/64> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El zapallo es una de las hortalizas más conocidas para hacer cremas, sopas o alguna otra preparación y últimamente han ganado mucha popularidad los pasteles de zapallo que son muy consumidos especialmente en la Semana Santa."^^xsd:string ;
    schema1:name "Torta de zapallo"^^xsd:string ;
    schema1:recipeIngredient """1 zapallo mediano
½ taza de leche
½ lb de azúcar
3 huevos
1 cucharadita de mantequilla
¼ lb de queso fresco
½ taza de pasas
2 cucharaditas de polvo de hornear
2 cucharaditas de canela en polvo
½ cucharadita de sal
1 copita de ron"""^^xsd:string ;
    schema1:recipeYield 12 .

<http://example.org/recipes/Confectionery/65> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Muchos de los desayunos en Ecuador tienen al plátano verde, o simplemente verde, como un ingrediente infaltable para sus preparaciones, en esta ocasión tortillas de verde."^^xsd:string ;
    schema1:name "Tortillas de verde"^^xsd:string ;
    schema1:recipeIngredient """3 plátanos verdes
1 cebolla morada picada
1 cucharadita de achiote
Queso mozzarella
1 vaso de aceite neutro
Sal a gusto"""^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Confectionery/66> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Uno de los postres frios preferidos es la tres leches. Esa mezcla de bizcocho mojado de leche con la crema por encima tiene un sabor único."^^xsd:string ;
    schema1:name "Tres leches ecuatoriana"^^xsd:string ;
    schema1:recipeIngredient """4 huevos
140 gr de azúcar
½ cucharada de esencia de vainilla
140 gr de harina
Para el liquido
1 lata leche condensada
1 lata leche evaporada
1 crema de leche 500 gramos
Para crema chantilly
1 sobre de crema chantilly
1 taza de leche fría"""^^xsd:string ;
    schema1:recipeYield 12 .

<http://example.org/recipes/Confectionery/67> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El turrón es sin duda uno de los más característicos postres de la Navidad, en Ecuador puedes encontrarlos durante todo el año en pueblos de la costa y en la sierra ecuatoriana."^^xsd:string ;
    schema1:name "Turrón dulce"^^xsd:string ;
    schema1:recipeIngredient """1 taza de almendras o avellanas tostadas y sin piel
½ taza de miel de abeja
2 obleas
2 claras de huevo
½ taza de azúcar
1 ½ tazas de azúcar impalpable
1 cucharadita de canela en polvo (opcional)"""^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Confectionery/68> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El turrón es considerado en todo el mundo un clásico de la Navidad, en Ecuador el ingrediente sorpresa son las obleas, el toque mágico de la  costa ecuatoriana."^^xsd:string ;
    schema1:name "Turrón dulce ecuatoriano"^^xsd:string ;
    schema1:recipeIngredient """1 taza de almendras tostadas
2 obleas
2 claras de huevo
100 gr de azúcar
300 gr de azúcar glass
½ taza de miel
1 cucharadita de canela"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Confectionery/69> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Es un postre clásico y muy rico que se prepara de una forma bastante fácil. Consiste de un biscocho bastante húmedo y jugoso que se baña en un caramelo con sabor a piña. Es muy común encontrarla en los hogares y en pastelerías, y puedes disfrutarla en cualquier ocasión."^^xsd:string ;
    schema1:name "Volteado de piña"^^xsd:string ;
    schema1:recipeIngredient """1 ½ tazas de harina de trigo
½ taza de mantequilla sin sal
1¼ tazas de azúcar
2 huevos
¾ de taza de yogur
1 cucharada de ron añejo
¼ de cucharadita de sal
1 lata de rebanadas de piña en almíbar"""^^xsd:string ;
    schema1:recipeYield 12 .

<http://example.org/recipes/Confectionery/7> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "El budín de pan es uno de los postres más fáciles de elaborar, pero lo sencillo no le quita lo exquisito"^^xsd:string ;
    schema1:name "Budín de pan"^^xsd:string ;
    schema1:recipeIngredient """10 panes de sal (no importa si es pan viejo)
1 lb de azúcar (o a tu gusto)
1 litro de leche
3 huevos
1 copa de ron o aguardiente
3 cucharadas de esencia de vainilla
½ lb de mantequilla derretida
½ taza de pasas (opcional)"""^^xsd:string ;
    schema1:recipeYield 8 .

<http://example.org/recipes/Confectionery/8> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Los buñuelos de mandioca son dulce clásicos ecuatorianos que utilizan la mandioca y la miel para formar un postre tradicional exquisito."^^xsd:string ;
    schema1:name "Buñuelos de mandioca"^^xsd:string ;
    schema1:recipeIngredient """500 gr de mandioca cocida
20 gr de manteca
2 huevos
100 gr de queso cremoso cortado en cubos
2 tazas de panela rayada
1 naranja para jugo
1 taza de agua
4 tazas de aceite para freír
1 cucharadita de polvo para hornear
1 pizca de sal"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Confectionery/9> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Confectionery.csv" ;
    schema1:description "Los buñuelos de yuca son postres tradicionales y que se pueden servir en cualquier momento, con el sabor del queso, la yuca y la miel forman una mezcla exquisita para degustar."^^xsd:string ;
    schema1:name "Buñuelos de yuca"^^xsd:string ;
    schema1:recipeIngredient """1 lb de yuca cocida
1 cucharadita de polvo para hornear
1 cucharada de  mantequilla 
2 huevos 
1 taza de queso cortado de trozos (no muy salado)
1 pizca de sal
4 tazas de aceite para freír
2 tazas de panela rayada
½ taza de agua
1 naranjilla (jugo)"""^^xsd:string ;
    schema1:recipeYield 20 .

<http://example.org/recipes/Drink/1> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "El batido de borojó es famoso en toda la población ecuatoriana debido a los efectos afrodisíacos naturales que se le conocen. Vale la pena probarlo!"^^xsd:string ;
