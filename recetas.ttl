    schema1:recipeYield 6 .

<http://example.org/recipes/Entrance/83> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Entrance.csv" ;
    schema1:description "Las tortillas de quinua son una delicia que se comparte en algunos hogares, pueden servirse calientes."^^xsd:string ;
    schema1:name "Tortillas de quinua"^^xsd:string ;
    schema1:recipeIngredient """2 tazas de quinua 
4 tazas de agua
3 huevos batidos completamente
1 taza de queso fresco picado en cuadritos
½ taza de queso parmesano
2 zanahorias amarillas picadas en trozos
1 cebolla colorada finamente picada 
1 pimiento picado
1 diente de ajo finamente picado
