    schema1:recipeYield 15 .

<http://example.org/recipes/Entrance/72> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Entrance.csv" ;
    schema1:description "El pan de yuca es un aperitivo originario de la costa ecuatoriana y uno de los platos más representativos de Ecuador. Su receta es muy sencilla y se suele consumir en el desayuno o merienda, aunque también está presente en la mesa a la hora del almuerzo como guarnición de otras comidas más fuertes."^^xsd:string ;
    schema1:name "Pan de Yuca"^^xsd:string ;
