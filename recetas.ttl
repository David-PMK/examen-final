<http://example.org/recipes/Main_Dish/91> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Main_Dish.csv" ;
    schema1:description "El puchero de cabeza de chancho con yucas es un delicioso guisado muy completo y popular que puede disfrutarse en un buen almuerzo. Es un plato bastante tradicional, lleno de sabores exquisitos que te invitamos a probar."^^xsd:string ;
