<http://example.org/recipes/Entrance/71> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Entrance.csv" ;
    schema1:description "El pan de ajo se puede servir sólo o acompañado de queso o embutido. Se puede preparar con antelación ya que aguanta crujiente hasta el día siguiente, aunque es mejor prepararlo la misma jornada."^^xsd:string ;
