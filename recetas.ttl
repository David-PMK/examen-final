<http://example.org/recipes/Drink/12> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "Deliciosa bebida a base de aguardiente de caña y limón. Se sirve bien fría con hielo."^^xsd:string ;
