<http://example.org/recipes/Drink/51> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "El tomate de árbol es muy común Ecuador y se cultiva en clima frío-templado de varías provincias de la sierra"^^xsd:string ;
