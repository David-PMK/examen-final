<http://example.org/recipes/Soup/85> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Soup.csv" ;
    schema1:description "Es una sopa tradicional de la Sierra Ecuatoriana que se elabora como un locro a base de maní, leche, col, papas y costillas de res. Es un plato delicioso que puedes disfrutar en días fríos en compañía de la familia."^^xsd:string ;
