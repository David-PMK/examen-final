    schema1:recipeIngredient """3 guineos o bananas
½ taza de azúcar
1 cucharadita de esencia de vainilla
2 tazas de leche
Hielo"""^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Drink/20> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "La chicha es una bebida que se prepara con la cocción de las cortezas y el núcleo de la piña y azúcar morena. La chicha de piña acompaña bien los almuerzos en todo Ecuador."^^xsd:string ;
    schema1:name "Chicha de piñas"^^xsd:string ;
    schema1:recipeIngredient """2 litros de agua
1 piña grande y madura
200 gr de panela o azúcar morena
Canela o clavo de olor"""^^xsd:string ;
    schema1:recipeYield 8 .

<http://example.org/recipes/Drink/21> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "Bebida típica de Ecuador. Compuesta por 7 maices. Su preparación tarda varios días para fermentarse."^^xsd:string ;
    schema1:name "Chicha de quito"^^xsd:string ;
    schema1:recipeIngredient """Cantidades iguales de cada uno:
Maíz negro
Maíz blanco
Maíz amarillo
Morocho
Canguil
Chulpi
Jora"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Drink/22> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "Es una bebida tradicional muy popular en la cultura otavaleña. Se prepara con siete diferentes clases de maíz, y se endulza con panela. Su sabor es refrescante y es típica en las fiestas del Yamor, de allí su nombre,  donde se agradece a la Madre Tierra por las cosechas."^^xsd:string ;
    schema1:name "Chicha del yamor"^^xsd:string ;
    schema1:recipeIngredient """1 taza de maíz blanco
1 taza de maíz negro
1 taza de maíz amarillo
1 taza de jora (maíz fermentado)
1 taza de canguil
1 taza de chulpi
1 taza de morocho
6 litros de agua
Miel de panela al gusto"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Drink/23> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "La chicha resbaladera es una bebida artesanal ecuatoriana preparada a base de arroz tradicional de la ciudad de Guayaquil. Su preparación es muy antigua, se ofrecía en las casas y en celebraciones especiales."^^xsd:string ;
    schema1:name "Chicha Resbaladera"^^xsd:string ;
    schema1:recipeIngredient """¼ kilo de arroz crudo
3 cucharadas de cebada en grano
8 tazas de agua 
2 palitos de canela
8 clavos de olor
8 granos de pimienta dulce (de olor)
6 tazas de leche
1 lata de leche condensada
½ taza de azúcar
2 cucharaditas de esencia de vainilla
Nuez moscada
Canela en polvo"""^^xsd:string ;
    schema1:recipeYield 5 .

<http://example.org/recipes/Drink/24> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "Es una bebida caliente exquisita y tradicional, que se prepara con el chocolate producido en la localidad de Ambato. Su sabor es fuerte debido a la pureza y calidad del chocolate, y con un aroma característico de las especias lo convertirán en una delicia irresistible."^^xsd:string ;
    schema1:name "Chocolate de ambato"^^xsd:string ;
    schema1:recipeIngredient """2 tabletas de chocolate amargo de ambato
1 litro de leche
5 rajas de canela
8 clavos de olor
½ taza de azúcar al gusto"""^^xsd:string ;
    schema1:recipeYield 0 .

<http://example.org/recipes/Drink/25> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "La chucula ecuatoriana, es una bebida tradicional de los pueblos originarios de Ecuador, realizada con plátanos, que se considera un energizante natural. Una delicia!"^^xsd:string ;
    schema1:name "Chucula"^^xsd:string ;
    schema1:recipeIngredient """4 plátanos maduros
2 tazas de azúcar morena
2 tazas de leche
1 cucharadita de esencia de vainilla
1 vaso de agua
Una rama de canela
4 cucharadas de queso blanco"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Drink/26> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "La chucula ecuatoriana, un riquísimo batido de maduro como energizante. Esta bebida es una las tradiciones culinarias de los pueblos indígenas que aún se conserva en Ecuador."^^xsd:string ;
    schema1:name "Chucula Ecuatoriana"^^xsd:string ;
    schema1:recipeIngredient """4 plátanos maduros pelados cortados en rodajas
4 palitos de canela
4 cucharadas de queso sin sal rallado
2 tazas de azúcar
2 tazas de leche
1 cucharadita de esencia de vainilla 
½ taza de agua"""^^xsd:string ;
    schema1:recipeYield 5 .

<http://example.org/recipes/Drink/27> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "El coctel Ecuatoriano es una rica bebida con licor o ron, con un toque de hierba buena."^^xsd:string ;
    schema1:name "Coctel ecuatoriano"^^xsd:string ;
    schema1:recipeIngredient """2 cucharadas de azúcar blanca o morena
8 hojas de hierba buena fresca
60 ml de ron blanco
120 ml de soda
Hielo picadito
Jugó de maracuya
½ limón picado en trocitos"""^^xsd:string ;
    schema1:recipeYield 2 .

<http://example.org/recipes/Drink/28> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "Los jugos, batidos y coladas son parte integral de la cultura de Ecuador. La colada de avena, también conocida como colada quaker, es una bebida tradicional ecuatoriana que generalmente se sirve en las comidas y se puede tomar caliente o frío."^^xsd:string ;
    schema1:name "Colada de Avena"^^xsd:string ;
    schema1:recipeIngredient """2 litros de agua 
3 tazas de avena entera remojada en 1 taza de agua
Las cortezas y el centro de 1 piña
10 palitos de canela
10 granos de pimienta dulce
5 clavos de olor
10 oz de panela
3 tazas de pulpa de naranjilla
½ cucharadita hierba luisa seca
La cáscara de 1 limón"""^^xsd:string ;
    schema1:recipeYield 5 .

<http://example.org/recipes/Drink/29> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "La colada morada es la bebida tradicional del pueblo ecuatoriano el día que se celebra la fiesta de los difuntos, las frutas autóctonas del país son protagonistas de esta celebración."^^xsd:string ;
    schema1:name "Colada de moras"^^xsd:string ;
    schema1:recipeIngredient """250 gr de arándanos
250 gr de moras
1 taza de piña
1 taza de pulpa de naranja
1 taza de frutillas
2 ramas de canela
Clavos de olor
Cáscara de 1 limón
Cáscara de 1 naranja
½ taza azúcar morena
½ taza de panela
½ cucharadita de hierba luisa seca
2 litros de agua"""^^xsd:string ;
    schema1:recipeYield 10 .

<http://example.org/recipes/Drink/3> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "El mango ecuatoriano se cultiva principalmente en la provincia del Guayas y la mayoría se exporta, pero también es muy consumido por la población local en varías presentaciones incluidos los batidos"^^xsd:string ;
    schema1:name "Batido de mango"^^xsd:string ;
    schema1:recipeIngredient """4 mangos grandes
1 litro de leche fresca o yogurt natural
Trozos de durazno para la decoración
Hielo y azúcar al gusto"""^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Drink/30> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "En Ecuador, como en otros países latinoamericanos, se celebra el Día de los Difuntos el 2 de Noviembre. Esta celebración va acompañada de una importante tradición gastronómica: la colada morada, una bebida espesa de color morado que se prepara con frutas típicas ecuatorianas, hierbas y especias."^^xsd:string ;
    schema1:name "Colada Morada"^^xsd:string ;
    schema1:recipeIngredient """2 litros de agua fría
4 rajas de canela
8 clavos de olor
la cáscara de 1 limón 
la cáscara de 1 naranja 
la cáscara de 1 piña 
½ taza azúcar granulada
½ taza de panela (o piloncillo)
2 hojas de laurel
½ cucharadita de hierba luisa seca
¼ kilo de mortiños (o arándano azul)
¼ kilo de moras
½ cucharadita de pimienta de olor molido
1 taza de pulpa de naranjilla
¼ taza de maicena disuelta en 1 taza de agua
1 taza de piña cortada en cubitos
½ taza de frutillas (o fresas) cortadas
½ taza de babaco cortado (opcional)"""^^xsd:string ;
    schema1:recipeYield 5 .

<http://example.org/recipes/Drink/31> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "Esta ensalada de frutas ecuatoriana contiene frutas exóticas deliciosas y muy frescas, como papaya, sambos, piña, mango, plátanos y acompañadas con jugo de naranjas. Esta ensalada puede comerse o beberse y de allí su característico nombre."^^xsd:string ;
    schema1:name "Ensalada come y bebe"^^xsd:string ;
    schema1:recipeIngredient """1 papaya grande
1 piña pelada
6 plátanos maduros
6 mangos
1 sambos
10 naranjas jugosas
Azúcar o miel al gusto"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Drink/32> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "Una de las razones por las que es conocido Ecuador en todo el mundo es su exquisito café, este cóctel granizado es ideal para beberlo en una tarde de calor."^^xsd:string ;
    schema1:name "Granizado de café"^^xsd:string ;
    schema1:recipeIngredient """3 tazas de café ecuatoriano
150 gr azúcar
3 tazas de agua
1 medida de coñac
100 gr de crema batida o chantilly
1 cucharadita de café en polvo"""^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Drink/33> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "El guarapo se hace con la caña de azúcar. Una bebida muy refrescante que tienen nutrientes, azucares,minerales y vitaminas beneficiosas para la salud"^^xsd:string ;
