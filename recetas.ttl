<http://example.org/recipes/Main_Dish/1> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Main_Dish.csv" ;
    schema1:description "El arroz es una de las principales bases de la alimentación de los ecuatorianos y acompañarlo con atún es una costumbre que tienen los habitantes principalmente de la costa y este plato es considerado una delicia"^^xsd:string ;
