<http://example.org/recipes/Drink/35> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "Es una bebida muy refrescante en los meses de calor. Preparada a base de almendras. Se sirve bien frio."^^xsd:string ;
    schema1:name "Horchata de almendra"^^xsd:string ;
    schema1:recipeIngredient """200 gr de almendras peladas
Un litro de agua
1 vaso de azúcar
Canela
1 limón rayadura"""^^xsd:string ;
    schema1:recipeYield 3 .

<http://example.org/recipes/Drink/36> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "Bebida nutritiva y refrescante. Tradicional de Ecuador. A base de avena, leche y canela."^^xsd:string ;
    schema1:name "Horchata de avena"^^xsd:string ;
    schema1:recipeIngredient """1 taza de avena
2 tazas de agua
2 lata de leche evaporada
¾ de taza de azúcar
