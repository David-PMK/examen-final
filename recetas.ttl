<http://example.org/recipes/Main_Dish/98> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Main_Dish.csv" ;
    schema1:description "El seco es un guiso típico de la gastronomía de Ecuador puede elaborarse con cualquier tipo de carne, el seco de carne de guanta es típico de la selva amazónica del ecuador."^^xsd:string ;
