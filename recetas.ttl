<http://example.org/recipes/Soup/40> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Soup.csv" ;
    schema1:description "El locro es un plato clásico de Ecuador que consiste en una sopa cremosa hecha a base de papas y queso. Es típico de la Sierra ecuatoriana y especialmente popular en el norte del país y Quito, donde también se conoce como locro quiteño."^^xsd:string ;
