<http://example.org/recipes/Main_Dish/114> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Main_Dish.csv" ;
    schema1:description "El tapao de pescado es un plato típico de la cocina esmeraldeña, y se basa en un preparado de pescado fresco o salado, plátano verde y aromatizado con hierbas como la chillangua, orégano o chirarán. En la receta tradicional, se cocina tapado con hojas de plátano."^^xsd:string ;
