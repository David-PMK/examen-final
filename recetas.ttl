<http://example.org/recipes/Drink/61> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Drink.csv" ;
    schema1:description "El rompope es una bebida ecuatoriana preparada con yemas de huevo, vainilla, canela, almendra molida, leche, azúcar y licor. Se sirve tradicionalmente en las festividades navideñas."^^xsd:string ;
