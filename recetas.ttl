        "pimienta y orégano al gusto"^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Soup/12> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Soup.csv" ;
    schema1:description "El caldo de gallina criolla es una deliciosa receta que se puede degustar en cualquier momento, además de ser una comida típica y fácil de preparar."^^xsd:string ;
    schema1:name "Caldo de gallina criolla"^^xsd:string ;
    schema1:recipeIngredient """1 gallina criolla
2 ½ litros de agua fría
