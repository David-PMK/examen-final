2 litros de consomé de pescado o agua
Sal"""^^xsd:string,
        "pimienta y comino al gusto"^^xsd:string ;
    schema1:recipeYield 6 .

<http://example.org/recipes/Main_Dish/23> a schema1:Recipe ;
