<http://example.org/recipes/Soup/14> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Soup.csv" ;
    schema1:description "El caldo de mondongo es un plato típico en la gastronomía ecuatoriana, es muy rico con mucho sabor, que se elabora bajo un proceso un poco laborioso pero que sin duda resultará en un plato suculento. Anímate a probarla."^^xsd:string ;
