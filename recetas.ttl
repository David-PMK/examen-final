Sal a gusto"""^^xsd:string ;
    schema1:recipeYield 4 .

<http://example.org/recipes/Entrance/63> a schema1:Recipe ;
    dct:source "C:\\Users\\davqi\\Desktop\\Web Semantica\\Examen Final\\Datos_limpios\\Entrance.csv" ;
    schema1:description "Rico, fresco y simple, el batido de guayaba es un indispensable en todas las playas y zona costera del Ecuador."^^xsd:string ;
